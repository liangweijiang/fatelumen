# App
APP_ENV=development
APP_PORT=8080
APP_BASE_URL=http://localhost:8080
WEB_BASE_URL=http://localhost:3000
LOG_LEVEL=info

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=your-db-name
DB_CHARSET=utf8mb4

# Redis (optional — uses in-memory cache if empty)
REDIS_ADDR=
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRE_HOURS=168

# Admin
ADMIN_JWT_SECRET=your-admin-jwt-secret-here
ADMIN_JWT_EXPIRE_HOURS=2
ADMIN_BOOTSTRAP_USER=admin
ADMIN_BOOTSTRAP_PASSWORD=your-admin-password
ADMIN_EMAILS=admin@example.com

# Auth
AUTH_PROVIDERS=google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback

# Renderer
RENDERER=chromedp
CHROMIUM_PATH=/usr/bin/chromium

# Job Queue
JOB_QUEUE=goroutine
JOB_WORKERS=4
JOB_POLL_INTERVAL_MS=1000
JOB_STALE_THRESHOLD_MINUTES=5

# Notifier
NOTIFIER=noop
RESEND_API_KEY=
NOTIFY_FROM=noreply@example.com

# LLM
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Payment
PAYMENT_PROVIDERS=stripe
PAYMENT_SUCCESS_URL=http://localhost:3000/pay/success
PAYMENT_CANCEL_URL=http://localhost:3000/pricing
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
ORDER_REPORT_PRICE_CENTS=999

# Quota
QUOTA_DAILY_LIMIT=3

# Rate Limiting
RATELIMIT_ENABLED=true
RATELIMIT_READING_PER_MIN=5
RATELIMIT_ORDER_PER_MIN=10
RATELIMIT_AUTH_PER_MIN=10
RATELIMIT_DEFAULT_PER_MIN=60

# Cloudflare R2 (optional)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE=
